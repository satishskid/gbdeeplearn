---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LearnerWorkspace from '../../components/LearnerWorkspace.jsx';
import ProtectedTutorPanel from '../../components/ProtectedTutorPanel.jsx';
---

<BaseLayout
  title="GreyBrain Learner Hub"
  description="Learner access area for enrolled healthcare AI participants."
  canonical="https://med.greybrain.ai/app/learn"
  navMode="app"
  noindex={true}
>
  <section class="mb-6 overflow-hidden rounded-[2.4rem] border border-slate-200/70 bg-[radial-gradient(circle_at_top_left,rgba(14,165,233,0.14),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(16,185,129,0.15),transparent_26%),linear-gradient(135deg,#081427_0%,#0f172a_58%,#12324f_100%)] px-6 py-8 text-white shadow-[0_30px_80px_rgba(15,23,42,0.18)] md:px-8 md:py-10">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-3xl">
        <p class="mb-3 inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.15em] text-cyan-100">
          Learner Mode
        </p>
        <h1 class="text-3xl font-extrabold leading-tight tracking-tight md:text-4xl">Continue your GreyBrain cohort with a clearer workflow.</h1>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-200 md:text-base">
          Access pre-reads, live sessions, assignment flow, capstone checkpoints, certificate progress, and tutor support after enrollment.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="rounded-full border border-white/12 bg-white/8 px-3 py-1 text-[11px] font-medium text-slate-100">Pre-reads and unlock flow</span>
          <span class="rounded-full border border-white/12 bg-white/8 px-3 py-1 text-[11px] font-medium text-slate-100">Assignments and live sessions</span>
          <span class="rounded-full border border-white/12 bg-white/8 px-3 py-1 text-[11px] font-medium text-slate-100">Tutor and certificate milestones</span>
        </div>
      </div>
      <div class="flex flex-wrap gap-2">
        <a
          href="/courses"
          class="inline-flex rounded-xl border border-white/20 bg-white/10 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/15"
        >
          Browse Courses
        </a>
        <a
          href="/"
          class="inline-flex rounded-xl border border-white/20 bg-white/10 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/15"
        >
          Back To Public Landing
        </a>
      </div>
    </div>
  </section>

  <LearnerWorkspace client:load />
  <div class="mt-6">
    <ProtectedTutorPanel client:load />
  </div>
</BaseLayout>
